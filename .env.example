PROJECT_NAME=Azeroth Nexus API
ENVIRONMENT=development
DEBUG=true

API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=3000
NGINX_PORT=80

DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/azeroth_nexus
REDIS_URL=redis://redis:6379/0

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
ADMIN_API_TOKEN=change-this-ops-token
INTERNAL_API_BASE_URL=http://localhost:8000

BLIZZARD_CLIENT_ID=
BLIZZARD_CLIENT_SECRET=
BLIZZARD_REGION=us

RAIDERIO_API_BASE_URL=https://raider.io/api
WARCRAFTLOGS_CLIENT_ID=
WARCRAFTLOGS_CLIENT_SECRET=

PROVIDER_TIMEOUT_SECONDS=20
CACHE_TTL_SECONDS=300
AUTO_REFRESH_INTERVAL_SECONDS=600
BACKUP_DIR=/var/backups/azerothnexus
